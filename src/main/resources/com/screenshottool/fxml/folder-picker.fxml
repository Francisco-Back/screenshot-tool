<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    folder-picker.fxml - Selector de carpeta de destino
    Controller: com.screenshottool.controller.FolderPickerController

    Layout:
      ┌──────────────────────────────────┐
      │  Carpeta de destino              │
      │  ┌────────────────────────────┐  │
      │  │ lblCarpetaActual (ruta)    │  │
      │  └────────────────────────────┘  │
      │  [Examinar...]                   │
      │                                  │
      │  [Confirmar]        [Cancelar]   │
      └──────────────────────────────────┘
-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.screenshottool.controller.FolderPickerController"
      spacing="12"
      prefWidth="440"
      styleClass="root-container"
      stylesheets="@../css/style.css">

    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <!-- ── Título ───────────────────────────────────────── -->
    <Label text="Carpeta de destino"
           styleClass="picker-titulo"/>

    <!-- ── Ruta actual ──────────────────────────────────── -->
    <VBox styleClass="picker-ruta-container" spacing="4">
        <Label text="Ruta seleccionada:" styleClass="lbl-campo"/>
        <Label fx:id="lblCarpetaActual"
               styleClass="picker-ruta"
               wrapText="true"
               maxWidth="400"/>
    </VBox>

    <!-- ── Botón examinar ───────────────────────────────── -->
    <Button fx:id="btnExaminar"
            text="📂  Examinar..."
            styleClass="btn-examinar"
            onAction="#onExaminar"
            prefWidth="160"/>

    <!-- ── Separador ────────────────────────────────────── -->
    <Separator/>

    <!-- ── Confirmar / Cancelar ─────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnConfirmar"
                text="✓  Confirmar"
                styleClass="btn-guardar"
                defaultButton="true"
                onAction="#onConfirmar"
                prefWidth="120"/>
        <Button fx:id="btnCancelar"
                text="✕  Cancelar"
                styleClass="btn-cancelar"
                cancelButton="true"
                onAction="#onCancelar"
                prefWidth="120"/>
    </HBox>

</VBox>
