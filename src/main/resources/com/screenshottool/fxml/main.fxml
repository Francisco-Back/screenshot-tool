<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    main.fxml — Fluent Design (Windows 11)
    CAMBIO CLAVE: el raíz ahora es StackPane (fx:id="rootPane")
    El VBox de contenido va dentro, y el toast se inyecta
    como segunda capa del StackPane desde el controller.
-->

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.screenshottool.controller.ScreenshotController"
           fx:id="rootPane"
           styleClass="root-container"
           stylesheets="@../css/style.css">

    <!-- ── Contenido principal (capa 1) ─────────────────────── -->
    <VBox spacing="0">

        <!-- Chip dimensiones -->
        <HBox alignment="CENTER">
            <VBox.margin><Insets top="14" bottom="6"/></VBox.margin>
            <Label fx:id="lblDimensiones" styleClass="lbl-info"/>
        </HBox>

        <!-- Preview -->
        <StackPane styleClass="preview-container">
            <VBox.margin><Insets top="4" left="16" right="16" bottom="4"/></VBox.margin>
            <ImageView fx:id="imgPreview"
                       fitWidth="500" fitHeight="260"
                       preserveRatio="true"/>
        </StackPane>

        <!-- Section card: nombre + formato + carpeta -->
        <VBox styleClass="section-card" spacing="10">
            <VBox.margin><Insets top="10" left="16" right="16"/></VBox.margin>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Nombre del archivo" styleClass="lbl-campo"/>
                    <TextField fx:id="txtNombre"
                               styleClass="txt-nombre"
                               promptText="captura_pantalla"
                               maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="3" minWidth="90">
                    <Label text="Formato" styleClass="lbl-campo"/>
                    <ComboBox fx:id="cmbFormato"
                              styleClass="cmb-formato"
                              prefWidth="90"/>
                </VBox>
            </HBox>

            <Separator opacity="0.5"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Guardar en" styleClass="lbl-campo"/>
                    <Label fx:id="lblCarpeta"
                           styleClass="lbl-carpeta"
                           maxWidth="Infinity"
                           wrapText="false"/>
                </VBox>
                <Button text="Cambiar"
                        styleClass="btn-cambiar"
                        onAction="#onCambiarCarpeta"/>
            </HBox>
        </VBox>

        <!-- Estado -->
        <Label fx:id="lblEstado"
               styleClass="lbl-estado"
               maxWidth="Infinity"
               alignment="CENTER_LEFT">
            <VBox.margin><Insets top="6" left="20" right="16" bottom="2"/></VBox.margin>
        </Label>

        <!-- Separador -->
        <Separator>
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Separator>

        <!-- Botones -->
        <HBox spacing="8" alignment="CENTER">
            <VBox.margin><Insets top="12" bottom="16"/></VBox.margin>
            <Button fx:id="btnGuardar"
                    text="Guardar"
                    styleClass="btn-guardar"
                    defaultButton="true"
                    onAction="#onGuardar"
                    prefWidth="120"/>
            <Button fx:id="btnCopiar"
                    text="Copiar imagen"
                    styleClass="btn-copiar"
                    onAction="#onCopiar"
                    prefWidth="130"/>
            <Button fx:id="btnCancelar"
                    text="Cancelar"
                    styleClass="btn-cancelar"
                    cancelButton="true"
                    onAction="#onCancelar"
                    prefWidth="100"/>
        </HBox>

    </VBox>

    <!-- El toast se agrega aquí dinámicamente desde el controller -->

</StackPane>
