<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.screenshottool.controller.ScreenshotController"
           fx:id="rootPane"
           styleClass="root-container"
           stylesheets="@../css/style.css"
           prefWidth="480">

    <VBox spacing="0" maxWidth="Infinity">

        <!-- Chip dimensiones -->
        <HBox alignment="CENTER">
            <VBox.margin><Insets top="12" bottom="4"/></VBox.margin>
            <Label fx:id="lblDimensiones" styleClass="lbl-info"/>
        </HBox>

        <!-- Preview -->
        <StackPane styleClass="preview-container">
            <VBox.margin><Insets top="6" left="16" right="16" bottom="6"/></VBox.margin>
            <ImageView fx:id="imgPreview"
                       fitWidth="448" fitHeight="220"
                       preserveRatio="true"/>
        </StackPane>

        <!-- Section card -->
        <VBox styleClass="section-card" spacing="8">
            <VBox.margin><Insets top="4" left="16" right="16"/></VBox.margin>

            <!-- Nombre + Formato -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Nombre del archivo" styleClass="lbl-campo"/>
                    <TextField fx:id="txtNombre"
                               styleClass="txt-nombre"
                               promptText="captura_pantalla"
                               maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="3" minWidth="88">
                    <Label text="Formato" styleClass="lbl-campo"/>
                    <ComboBox fx:id="cmbFormato"
                              styleClass="cmb-formato"
                              prefWidth="88"/>
                </VBox>
            </HBox>

            <Separator opacity="0.4"/>

            <!-- Carpeta: mitad izquierda nombre, mitad derecha botón Cambiar -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="📁" styleClass="lbl-folder-icon"/>
                <VBox HBox.hgrow="ALWAYS" spacing="1">
                    <Label text="Guardar en" styleClass="lbl-campo"/>
                    <Label fx:id="lblCarpeta"
                           styleClass="lbl-carpeta"
                           maxWidth="Infinity"
                           wrapText="false"/>
                </VBox>
                <Button text="Cambiar"
                        styleClass="btn-cambiar-inline"
                        onAction="#onCambiarCarpeta"
                        prefWidth="110"/>
            </HBox>
        </VBox>

        <!-- Estado -->
        <Label fx:id="lblEstado"
               styleClass="lbl-estado"
               maxWidth="Infinity"
               alignment="CENTER_LEFT">
            <VBox.margin><Insets top="4" left="20" right="16" bottom="0"/></VBox.margin>
        </Label>

        <!-- Separador -->
        <Separator>
            <VBox.margin><Insets top="8"/></VBox.margin>
        </Separator>

        <!-- Botones -->
        <HBox spacing="8" alignment="CENTER">
            <VBox.margin><Insets top="10" bottom="14" left="16" right="16"/></VBox.margin>
            <Button fx:id="btnGuardar"
                    text="Guardar"
                    styleClass="btn-guardar"
                    defaultButton="true"
                    onAction="#onGuardar"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"/>
            <Button fx:id="btnCopiar"
                    text="Copiar imagen"
                    styleClass="btn-copiar"
                    onAction="#onCopiar"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"/>
            <Button fx:id="btnCancelar"
                    text="Cancelar"
                    styleClass="btn-cancelar"
                    cancelButton="true"
                    onAction="#onCancelar"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"/>
        </HBox>

    </VBox>

</StackPane>
